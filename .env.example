# ── Server deployment (docker-compose-server.yml) ──
# COMPOSE_FILE=docker-compose-server.yml
# HOSTNAME=example.home.yourdomain.com    # Base domain for Traefik routing (prometheus.HOSTNAME, dashboard.HOSTNAME, loki.HOSTNAME)

# ── Node deployment (docker-compose-node.yml) ──
# COMPOSE_FILE=docker-compose-node.yml
# TAILSCALE_IP=100.x.x.x                 # Required: This host's Tailscale IP (cAdvisor binds to this)
# CADVISOR_PORT=8080                      # Optional: Defaults to 8080, change if port conflicts
# NODE_HOSTNAME=myhost                    # Required: Hostname used in Fluent Bit log labels
